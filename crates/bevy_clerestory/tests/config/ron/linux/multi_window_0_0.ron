(
    version: 2,
    entries: [
        (
            key: Primary,
            state: (
                // Monitor 0 (eDP) — 200px offset from monitor origin
                logical_position: Some((${MONITOR_0_LOGICAL_POS_X+200}, ${MONITOR_0_LOGICAL_POS_Y+200})),
                logical_width: 1000,
                logical_height: 700,
                monitor_scale: 1.0,
                monitor_index: 0,
                mode: Windowed,
                app_name: "restore_window",
            )
        ),
        (
            key: Managed("window-1"),
            state: (
                // Secondary window also on Monitor 0 — offset from origin (must fit within monitor)
                logical_position: Some((${MONITOR_0_LOGICAL_POS_X+400}, ${MONITOR_0_LOGICAL_POS_Y+200})),
                logical_width: 1200,
                logical_height: 800,
                monitor_scale: 1.0,
                monitor_index: 0,
                mode: Windowed,
                app_name: "restore_window",
            )
        ),
    ],
)
