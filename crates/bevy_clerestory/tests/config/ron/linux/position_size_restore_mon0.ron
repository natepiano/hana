(
    version: 2,
    entries: [
        (
            key: Primary,
            state: (
                // Monitor 0 (eDP) — position window with 200px offset from monitor origin
                logical_position: Some((${MONITOR_0_LOGICAL_POS_X+200}, ${MONITOR_0_LOGICAL_POS_Y+200})),
                logical_width: 1000,
                logical_height: 700,
                monitor_scale: 1.0,
                monitor_index: 0,
                mode: Windowed,
                app_name: "restore_window",
            )
        ),
    ],
)
