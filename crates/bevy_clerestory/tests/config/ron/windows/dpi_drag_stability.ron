(
    version: 2,
    entries: [
        (
            key: Primary,
            state: (
                // DPI drag stability test (W2 workaround)
                // Window starts on Monitor 1 (low-DPI), user drags to Monitor 0 (high-DPI)
                // Tests that window moves smoothly without bouncing or incorrect resize
                logical_position: Some((${MONITOR_1_LOGICAL_POS_X}, ${MONITOR_1_LOGICAL_POS_Y})),
                logical_width: 1200,
                logical_height: 800,
                monitor_scale: 1.0,
                monitor_index: 1,
                mode: Windowed,
                app_name: "restore_window",
            )
        ),
    ],
)
